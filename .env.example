# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email
RESEND_API_KEY=your-resend-api-key

# App
APP_URL=http://localhost:3000

# PostHog analytics
# Get your project API key from PostHog dashboard → Settings → Project API key
# Host: https://eu.i.posthog.com (EU cloud) or https://us.i.posthog.com (US cloud)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Required: random secret for Vercel cron job authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your-secret-here

# Rate limiting (required before public launch)
# Create a free Redis database at https://upstash.com
UPSTASH_REDIS_REST_URL=your-url-here
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Python extraction service authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EXTRACTION_SERVICE_SECRET=your-secret-here
PYTHON_SERVICE_URL=https://your-railway-service.railway.app
# Optional: run legacy extraction in shadow mode and log before/after comparison
EXTRACT_COMPARE_WITH_LEGACY=false
