ANTHROPIC_API_KEY=your-key-here

# Shared secret — must match EXTRACTION_SERVICE_SECRET in the Next.js app
EXTRACTION_SERVICE_SECRET=your-secret-here

# Supabase storage domain for SSRF allowlist (e.g. xxxx.supabase.co)
# Only needed if PDFs are fetched by URL instead of the shared volume
ALLOWED_STORAGE_DOMAIN=

# Optional — AI model overrides
# AI_MODEL=claude-sonnet-4-6           # extraction model (default: claude-sonnet-4-6)
# ANALYSIS_MODEL=claude-haiku-4-5-20251001  # analysis model (default: claude-haiku-4-5-20251001)
